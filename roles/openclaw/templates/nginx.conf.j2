map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Detect if this is a WebSocket request
map $http_upgrade $is_websocket {
    default 0;
    websocket 1;
}

server {
    listen 80;
    server_name _;

    # WebSocket connections go directly to OpenClaw
    location @openclaw_ws {
        proxy_pass http://openclaw:{{ openclaw_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    # Root path - serve landing page OR proxy WebSocket
    location = / {
        # WebSocket upgrade requests go to OpenClaw
        if ($is_websocket) {
            rewrite ^ /ws_proxy last;
        }

        # Regular browser requests get the landing page
        root /usr/share/nginx/html;
        try_files /landing.html =404;
    }

    # Internal WebSocket proxy location
    location = /ws_proxy {
        internal;
        proxy_pass http://openclaw:{{ openclaw_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    # All other paths proxy to OpenClaw
    location / {
        proxy_pass http://openclaw:{{ openclaw_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }
}
